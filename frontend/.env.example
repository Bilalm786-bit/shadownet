# Frontend env vars (Vite reads VITE_*)
#
# Local development: leave VITE_API_URL empty so the Vite proxy in
# vite.config.ts forwards /api and /ws to http://localhost:8000.
#
# Production (Vercel): set this to your Render backend origin, e.g.
#   VITE_API_URL=https://shadownet-backend.onrender.com
VITE_API_URL=
