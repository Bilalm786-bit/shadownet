# ShadowNet — Environment Configuration
# Copy to .env and fill in your values

# ─── App ────────────────────────────────────────────────
APP_NAME=ShadowNet
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=change-this-to-a-random-64-char-string
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ─── PostgreSQL ─────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://shadownet:shadownet_secret_2024@localhost:5432/shadownet

# ─── Neo4j ──────────────────────────────────────────────
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=shadownet_graph_2024

# ─── Elasticsearch ──────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200

# ─── Redis ──────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── MinIO / S3 ────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=shadownet
MINIO_SECRET_KEY=shadownet_minio_2024
MINIO_BUCKET=shadownet-evidence

# ─── OpenAI (ChatGPT 5.5) ──────────────────────────────
OPENAI_API_KEY=your-chatgpt-5.5-api-key-here
OPENAI_MODEL=gpt-5.5

# ─── JWT Auth ───────────────────────────────────────────
JWT_SECRET_KEY=change-this-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
